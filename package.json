{
  "name": "pomodoro",
  "version": "0.1.0",
  "productName": "Pomodoro",
  "description": "Minimal desktop pomodoro timer with a 300x300 always-on-top work window.",
  "main": "dist/main/index.js",
  "author": "Pomodoro Dev",
  "license": "MIT",
  "homepage": "https://github.com/dragoneagle/pomodoro",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.pomodoro.app",
    "productName": "Pomodoro",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["dist/**/*", "package.json"],
    "asar": true,
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "Pomodoro Dev"
    },
    "deb": {
      "afterInstall": "build/after-install.sh"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity"
    }
  }
}
